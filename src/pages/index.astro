---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const currentPath = Astro.url.pathname;

const skills = [
  'PHP', 'Symfony', 'Python', 'Django', 'JavaScript',
  'React', 'PostgreSQL', 'MySQL', 'Docker', 'Git', 'CI/CD'
];
---

<Layout
  title="Yohan Diaz | Backend Entwickler"
  description="Backend Entwickler mit Schwerpunkt auf der Entwicklung skalierbarer und effizienter Webanwendungen mit PHP (Symfony) und Python (Django)."
>
  <Navbar currentPath={currentPath} />

  <main class="min-h-screen px-4 sm:px-6 md:px-6">
    <!-- Hero Section -->
    <section class="max-w-3xl mx-auto min-h-[calc(100vh-5rem)] flex flex-col justify-center pt-32 sm:pt-48 pb-16 sm:pb-24 fade-in">
      <div class="flex flex-col items-center gap-6 sm:gap-8 text-center">
        <!-- Photo + Badge -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
          <div class="w-24 h-24 sm:w-28 sm:h-28 md:w-32 md:h-32 rounded-full bg-gray-100 dark:bg-gray-800 border-2 border-gray-300 dark:border-gray-600 flex items-center justify-center overflow-hidden animated-border always-visible flex-shrink-0 shadow-lg dark:shadow-white/20">
            <span class="text-4xl sm:text-5xl md:text-6xl">👨‍💻</span>
          </div>
          <div class="animated-border always-visible px-3 sm:px-4 py-2 rounded-full border border-gray-300 dark:border-gray-600 h-fit">
            <p
              class="text-xs sm:text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap"
              data-en="Open to work"
              data-de="Offen für Arbeit"
              data-es="Disponible"
            >
              Open to work
            </p>
          </div>
        </div>

        <!-- Name and Description -->
        <div>
          <p
            class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-2"
            data-en="Hello, I'm"
            data-de="Hallo, ich bin"
            data-es="Hola, soy"
          >
            Hello, I'm
          </p>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 px-2 sm:px-0">
            Yohan Diaz
          </h1>
          <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-lg mx-auto mb-4 sm:mb-6 px-2 sm:px-0">
            <span class="font-semibold text-gray-900 dark:text-white" data-en="Backend Developer" data-de="Backend Entwickler" data-es="Desarrollador Backend">Backend Developer</span>
            <span data-en=" focused on building scalable and efficient web applications with PHP (Symfony) and Python (Django)." data-de=" mit Schwerpunkt auf der Entwicklung skalierbarer und effizienter Webanwendungen mit PHP (Symfony) und Python (Django)." data-es=" enfocado en construir aplicaciones web escalables y eficientes con PHP (Symfony) y Python (Django).">
              focused on building scalable and efficient web applications with PHP (Symfony) and Python (Django).
            </span>
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-2 sm:gap-3 justify-center px-2 sm:px-0">
            <a
              href="#projects"
              class="cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-medium rounded-full hover:animated-bg transition-all"
              data-en="View Projects"
              data-de="Projekte ansehen"
              data-es="Ver Proyectos"
            >
              View Projects
            </a>
            <a
              href="#contact"
              class="animated-border cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-medium rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
              data-en="Get in Touch"
              data-de="Kontakt aufnehmen"
              data-es="Contactar"
            >
              Get in Touch
            </a>
          </div>

          <!-- CV Download Card -->
          <div class="mt-8 sm:mt-10 flex justify-center px-2 sm:px-0">
            <article class="cv-download-card group" aria-label="Download CV card">
              <div class="cv-download-card-inner">
                <div class="text-gray-50 text-left">
                  <span class="cv-initials">YD</span>
                  <p class="cv-role" data-en="Backend Developer" data-de="Backend Entwickler" data-es="Desarrollador Backend">Backend Developer</p>
                </div>
                <a href="/CV_Yohan_Diaz_Acosta.pdf" download class="cv-download-button">
                  <span data-en="Download CV" data-de="Lebenslauf herunterladen" data-es="Descargar CV">Download CV</span>
                  <svg class="w-5 h-5 fill-current" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M22.1,77.9a4,4,0,0,1,4-4H73.9a4,4,0,0,1,0,8H26.1A4,4,0,0,1,22.1,77.9ZM35.2,47.2a4,4,0,0,1,5.7,0L46,52.3V22.1a4,4,0,1,1,8,0V52.3l5.1-5.1a4,4,0,0,1,5.7,0,4,4,0,0,1,0,5.6l-12,12a3.9,3.9,0,0,1-5.6,0l-12-12A4,4,0,0,1,35.2,47.2Z" fill-rule="evenodd"></path>
                  </svg>
                </a>
              </div>

              <svg class="cv-avatar cv-avatar-main" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" aria-hidden="true">
                <path d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"/>
              </svg>
              <svg class="cv-avatar cv-avatar-accent" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" aria-hidden="true">
                <path d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"/>
              </svg>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
      <h2
        class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8"
        data-en="About Me"
        data-de="Über mich"
        data-es="Sobre mí"
      >
        About Me
      </h2>
      <div class="space-y-3 sm:space-y-4 text-base sm:text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        <p data-en="I am a Backend Developer focused on building scalable and efficient web applications. My focus is on implementing robust systems with PHP (Symfony) and Python (Django). I have solid knowledge in relational databases and proven experience in designing and implementing RESTful APIs." data-de="Ich bin ein Backend-Entwickler mit Schwerpunkt auf der Entwicklung skalierbarer und effizienter Webanwendungen. Mein Fokus liegt auf der Umsetzung robuster Systeme mit PHP (Symfony) und Python (Django). Ich verfüge über fundierte Kenntnisse in relationalen Datenbanken sowie nachweisliche Erfahrung im Design und in der Implementierung von RESTful APIs.">
          I am a Backend Developer focused on building scalable and efficient web applications. My focus is on implementing robust systems with PHP (Symfony) and Python (Django). I have solid knowledge in relational databases and proven experience in designing and implementing RESTful APIs.
        </p>
        <p data-en="In my previous projects, I have worked on high-performance and highly available applications, applying best practices in software development. I place particular emphasis on clean, maintainable code and collaboration in interdisciplinary teams to deliver high-quality and sustainable solutions." data-de="In meinen bisherigen Projekten habe ich an leistungsstarken und hochverfügbaren Anwendungen gearbeitet und dabei Best Practices in der Softwareentwicklung angewandt. Besonderen Wert lege ich auf sauberen, wartbaren Code und die Zusammenarbeit in interdisziplinären Teams, um hochwertige und nachhaltige Lösungen zu liefern.">
          In my previous projects, I have worked on high-performance and highly available applications, applying best practices in software development. I place particular emphasis on clean, maintainable code and collaboration in interdisciplinary teams to deliver high-quality and sustainable solutions.
        </p>
      </div>

      <!-- Stats -->
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="text-center p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">5+</div>
          <div class="text-xs text-gray-600 dark:text-gray-400" data-en="Years Experience" data-de="Jahre Erfahrung">Years Experience</div>
        </div>
        <div class="text-center p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">3</div>
          <div class="text-xs text-gray-600 dark:text-gray-400" data-en="Languages" data-de="Sprachen">Languages</div>
        </div>
        <div class="text-center p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">M.Sc.</div>
          <div class="text-xs text-gray-600 dark:text-gray-400" data-en="Big Data" data-de="Big Data">Big Data</div>
        </div>
        <div class="text-center p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">B2</div>
          <div class="text-xs text-gray-600 dark:text-gray-400" data-en="German" data-de="Deutsch">German</div>
        </div>
      </div>
    </section>

    <!-- Tech Stack Section -->
    <section class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
      <h2
        class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8"
        data-en="Tech Stack"
        data-de="Technologien"
        data-es="Tecnologías"
      >
        Tech Stack
      </h2>

      <div class="tech-ticker-container">
        <div class="tech-ticker-content">
          {/* First set */}
          {skills.map((skill) => (
            <div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
              <p class="text-sm font-medium text-gray-900 dark:text-white">{skill}</p>
            </div>
          ))}
          {/* Second set for seamless looping */}
          {skills.map((skill) => (
            <div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
              <p class="text-sm font-medium text-gray-900 dark:text-white">{skill}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Skills Grid -->
      <div class="mt-8 grid grid-cols-2 gap-4">
        <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2" data-en="Languages" data-de="Sprachen">Languages</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">PHP, Python, JavaScript</p>
        </div>
        <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Frameworks</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">Symfony, Django, React</p>
        </div>
        <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2" data-en="Databases" data-de="Datenbanken">Databases</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">PostgreSQL, MySQL, SQL Server</p>
        </div>
        <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">DevOps & Tools</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">Docker, Git, CI/CD, PHPUnit</p>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
      <h2
        class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8"
        data-en="Experience"
        data-de="Berufserfahrung"
        data-es="Experiencia"
      >
        Experience
      </h2>

      <div class="space-y-6">
        <!-- Current -->
        <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white" data-en="Backend Developer - Freelance" data-de="Backend Entwickler - Freiberuflich">Backend Developer - Freelance</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400 px-3 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 rounded-full w-fit" data-en="Current" data-de="Aktuell">Current</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Basel, Switzerland</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">Python, Django, Django Rest Framework, JavaScript, HTML, CSS, Git</p>
        </div>

        <!-- WSU -->
        <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white" data-en="ICT System Admin / Programmer" data-de="ICT-System-Admin / Programmierer">ICT System Admin / Programmer</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">Aug 2023 - Apr 2024</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-2" data-en="Department of Economy, Social Affairs and Environment (WSU), Canton Basel-Stadt" data-de="Departement für Wirtschaft, Soziales und Umwelt (WSU), Kanton Basel-Stadt">Department of Economy, Social Affairs and Environment (WSU), Canton Basel-Stadt</p>
          <ul class="text-sm text-gray-600 dark:text-gray-400 list-disc list-inside space-y-1">
            <li data-en="Development of prototypes for REST data exchange in Python" data-de="Entwicklung von Prototypen für REST-Datenaustausch in Python">Development of prototypes for REST data exchange in Python</li>
            <li data-en="Programming of OCR recognition solution prototype" data-de="Programmierung eines OCR-Erkennungslösung-Prototyps">Programming of OCR recognition solution prototype</li>
            <li data-en="Optimization of JaxForms platform" data-de="Optimierung der JaxForms-Plattform">Optimization of JaxForms platform</li>
          </ul>
        </div>

        <!-- Artemis -->
        <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white" data-en="Frontend Developer" data-de="Frontend Entwickler">Frontend Developer</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">Jul 2023 - Nov 2023</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Artemis IPM GmbH, Basel</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">React.js, TypeScript, Tailwind, Scala, MySQL, Vitest, Git</p>
        </div>

        <!-- Factor Energia -->
        <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white" data-en="Backend Developer" data-de="Backend Entwickler">Backend Developer</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">May 2021 - Jun 2022</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Factor Energia, Barcelona, Spain</p>
          <ul class="text-sm text-gray-600 dark:text-gray-400 list-disc list-inside space-y-1">
            <li data-en="Maintenance of company's legacy code program" data-de="Wartung des Legacy-Code-Programms">Maintenance of company's legacy code program</li>
            <li data-en="Development of new features for web applications" data-de="Entwicklung neuer Funktionen für Webanwendungen">Development of new features for web applications</li>
            <li data-en="Integration of third-party APIs and services" data-de="Integration von Drittanbieter-APIs und -Diensten">Integration of third-party APIs and services</li>
          </ul>
        </div>

        <!-- HEADER -->
        <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white" data-en="Backend Developer" data-de="Backend Entwickler">Backend Developer</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">Sep 2020 - Apr 2021</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">HEADER, Barcelona, Spain</p>
          <ul class="text-sm text-gray-600 dark:text-gray-400 list-disc list-inside space-y-1">
            <li data-en="Migration of 'Voto Electrónico' web application to Symfony 3" data-de="Migration der Webanwendung 'Voto Electrónico' zu Symfony 3">Migration of "Voto Electrónico" web application to Symfony 3</li>
            <li data-en="Development of new modules for shareholder meeting platforms" data-de="Entwicklung neuer Module für Hauptversammlungs-Plattformen">Development of new modules for shareholder meeting platforms</li>
            <li data-en="Database optimization for efficient data management" data-de="Datenbankoptimierung für effizientes Datenmanagement">Database optimization for efficient data management</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
      <h2
        class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8"
        data-en="Projects"
        data-de="Projekte"
        data-es="Proyectos"
      >
        Projects
      </h2>

      <div class="grid gap-6">
        <!-- Project 1 -->
        <div class="group p-6 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600 transition-all hover:shadow-lg">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2" data-en="REST Data Exchange System" data-de="REST-Datenaustausch-System">
                REST Data Exchange System
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-3" data-en="Prototype for REST data exchange with OCR recognition for PDF processing" data-de="Prototyp für REST-Datenaustausch mit OCR-Erkennung für PDF-Verarbeitung">
                Prototype for REST data exchange with OCR recognition for PDF processing
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-2 py-1 text-xs rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">Python</span>
                <span class="px-2 py-1 text-xs rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">Django REST</span>
                <span class="px-2 py-1 text-xs rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">OCR</span>
              </div>
            </div>
            <div class="flex gap-3">
              <a href="#" class="p-2 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors" aria-label="View code">
                <svg class="w-5 h-5 text-gray-600 dark:text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Project 2 -->
        <div class="group p-6 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600 transition-all hover:shadow-lg">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2" data-en="Electronic Voting Platform" data-de="Elektronische Wahl-Plattform">
                Electronic Voting Platform
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-3" data-en="Migration and modernization of shareholder meeting voting system" data-de="Migration und Modernisierung des Abstimmungssystems für Hauptversammlungen">
                Migration and modernization of shareholder meeting voting system
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-2 py-1 text-xs rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">PHP</span>
                <span class="px-2 py-1 text-xs rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">Symfony</span>
                <span class="px-2 py-1 text-xs rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">PostgreSQL</span>
              </div>
            </div>
            <div class="flex gap-3">
